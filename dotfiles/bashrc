#!/usr/bin/env bash

# Loads all Homelab support

# Do nothing if not running interactively
[[ -n $PS1 ]] || return

# ===================================================================
# ENVIRONMENT
# ===================================================================

CONFIG_DIR="$HOME/.config/homelab"
CONFIG_FILE="$CONFIG_DIR/homelab.conf"
ENV_FILE="$CONFIG_DIR/homelab.env"
HOMELAB_ROOT="$(git -C "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" rev-parse --show-toplevel)"

export EDITOR="nano" PAGER="less"
# The -D<letter>+<8-bit-number> color syntax needs a newer `less` than some
# hosts have (e.g. less 590 rejects it entirely, regardless of letter;
# 668 accepts it). -D only recolors less's own chrome (line numbers,
# prompts, search hits) -- content piped in (git diff, delta, grep) is
# already ANSI-colored and renders fine via plain -R -- so on unsupported
# hosts, drop -D entirely rather than risk another unsupported variant.
_lessColorFull="-R --use-color -Dd+209 -Du+117 -DP16.44 -DS16.220 -DN239 -DE231.203 -DM141"
if printf '' | LESS="$_lessColorFull" less -F -Q 2>&1 | grep -q "Invalid color string"; then
	export LESS="-R --use-color"
else
	export LESS="$_lessColorFull"
fi
unset _lessColorFull
export GREP_COLORS='mt=01;38;5;209:fn=38;5;117:ln=38;5;239:se=38;5;239'
export HISTCONTROL="ignoredups" HISTSIZE=5000 HISTFILESIZE=5000
export TZ='America/Chicago'
export GIT_DEFAULT_BRANCH="main"

# Make sure there is a nano backup directory
mkdir -p "$HOME/.nanobackup"

# Update environment
if [[ -f ${ENV_FILE} ]]; then
        source ${ENV_FILE}
fi

# Shell options
shopt -s cdspell
shopt -s checkwinsize
shopt -s autocd   2>/dev/null || true
shopt -s dirspell 2>/dev/null || true

# Aliases
alias ..='echo "cd .."; cd ..'
alias ...='echo "cd ../.."; cd ../..'
alias ....='echo "cd ../../.."; cd ../../..'
alias whereami='curl -sSf --connect-timeout 3 https://ipinfo.io/city 2>/dev/null || echo "NO CONNECTION"'
alias ls='ls --group-directories-first --color=auto -p'
alias l='ls'
alias ll='ls -hAlF'
alias flushdns='resolvectl flush-caches'
alias update-all='runElevated apt update && runElevated apt upgrade -y'
grep --color=auto < /dev/null &>/dev/null && alias grep='grep --color=auto'

eval $(dircolors -b "$HOMELAB_ROOT/dotfiles/dircolors" 2>/dev/null || dircolors -b)

if command -v batcat >/dev/null 2>&1; then
        alias bat='batcat'
fi

if command -v ncdu >/dev/null 2>&1; then
        alias du='ncdu -x -e --color dark'
fi

# ===================================================================
# REPOSITORY CHECKS: Start checks in background
# ===================================================================

source "$HOMELAB_ROOT/scripts/bash/git/check-repo.sh"

# Source repo list early so _NON_HOMELAB_REPOS is known before fetching
[[ -f "$HOME/.bashrc.d/check-my-repos.sh" ]] && source "$HOME/.bashrc.d/check-my-repos.sh"

# Start all repo fetches in parallel immediately to overlap with startup tasks
_fetch_pids=()
_fetch_repos=()
for _r in "$HOMELAB_ROOT" "${_NON_HOMELAB_REPOS[@]}"; do
        if [[ -d "$_r/.git" ]]; then
                git -C "$_r" fetch --quiet >/dev/null 2>&1 &
                _fetch_pids+=($!)
                _fetch_repos+=("$_r")
        fi
done
unset _r

# Track the last checked repo to avoid redundant checks while navigating within it
_last_checked_repo=""

# ===================================================================
# FUNCTIONS
# ===================================================================

runElevated() {
    [[ $EUID != 0 ]] && sudo "$@" || "$@"
    return $?
}

cdhl() {
        cd "$HOMELAB_ROOT"
}

cdhp() {
        # Change to private homelab directory
        if [[ -d ~/homelab_priv ]]; then
                cd ~/homelab_priv
        fi
}

# cd hook: check non-homelab repos when first navigating into them.
# _NON_HOMELAB_REPOS is defined in .bashrc.d/check-my-repos.sh
cd() {
        builtin cd "$@" || return
        [[ "${#_NON_HOMELAB_REPOS[@]}" -eq 0 ]] && return 0
        local _cd_repo
        for _cd_repo in "${_NON_HOMELAB_REPOS[@]}"; do
                if [[ "$PWD" == "$_cd_repo" || "$PWD" == "$_cd_repo/"* ]]; then
                        if [[ "$_last_checked_repo" != "$_cd_repo" ]]; then
                                _last_checked_repo="$_cd_repo"
                                checkRepo "$_cd_repo"
                        fi
                        return 0
                fi
        done
        _last_checked_repo=""
}

getPackageManager() {
        # Determine Package Manager
        for packageManager in apt dnf; do
                if command -v $packageManager &>/dev/null; then
                        echo $packageManager
                        return
                fi
        done
}

initializeHomelab() {

        # Make sure config directory exists
        mkdir -p "$CONFIG_DIR"

        # Check for existence of the config file
        if [[ ! -f "$CONFIG_FILE" ]]; then
                # Add default set of applications to new config
                jq -n '{
                        allApps: ["ncdu","bat","mc","git-delta"],
                        aptApps: ["screenfetch"],
                        dnfApps: ["fastfetch"],
                        excludeApps: [],
                        diskThreshold: 75
                }' > "$CONFIG_FILE"
                echo -e "Homelab config file created: $CONFIG_FILE\n"
        fi
}

installApps() {
    local packageManager=$(getPackageManager)
    local requiredApps=()

    if [[ -z $packageManager ]]; then
        echo "No supported package managers found. Nothing will be installed."
        return 1
    fi

    local temp_json
    temp_json="$(mktemp)"

    # Migrate legacy config files missing optional fields
    jq '.excludeApps //= [] | .diskThreshold //= 75' "$CONFIG_FILE" > "$temp_json" && mv "$temp_json" "$CONFIG_FILE"

    mapfile -t excludeApps < <(jq -r '.excludeApps[]' "$CONFIG_FILE")
    if [[ $packageManager == "apt" ]]; then
        installedApps="$(apt list --installed 2>/dev/null)"
        mapfile -t requiredApps < <(jq -r '.allApps[] , .aptApps[]' "$CONFIG_FILE")
    elif [[ $packageManager == "dnf" ]]; then
        installedApps="$(dnf list installed 2>/dev/null)"
        mapfile -t requiredApps < <(jq -r '.allApps[] , .dnfApps[]' "$CONFIG_FILE")
    fi

    local repositoryUpdated=''
    for app in "${requiredApps[@]}"; do
        if echo "$installedApps" | grep "^$app[/\.]" >/dev/null 2>&1; then
            continue
        fi

        if [[ " ${excludeApps[*]} " == *" $app "* ]]; then
                echo -e "$app was added to the exclude list and will be skipped\n"
                continue
        fi

        case $packageManager in
        apt)
            [[ $repositoryUpdated != 'y' ]] && echo "Updating repositories..." && runElevated apt update -q > /dev/null 2>&1 && repositoryUpdated='y'
            echo "Installing $app..."
            runElevated apt install -y "$app" > /dev/null 2>&1
            ;;
        dnf)
            [[ $repositoryUpdated != 'y' ]] && echo "Updating repositories..." && runElevated dnf update -q -y && runElevated dnf install epel-release -q -y && repositoryUpdated='y'
            echo "Installing $app..."
            runElevated dnf install -y "$app" 2>&1
            ;;
        esac

        if (( $? > 0 )); then
            echo "Install failed! Adding $app to the list of excluded apps."
            jq --arg app "$app" '.excludeApps += [$app]' "$CONFIG_FILE" > "$temp_json" && mv "$temp_json" "$CONFIG_FILE"
        fi
    done
}

_prompt_command() {
        local user=$USER
        local host=${HOSTNAME%%.*}
        local pwd=${PWD/#$HOME/\~}
        local ssh=
        [[ -n $SSH_CLIENT ]] && ssh='[ssh] '
        printf "\033]0;%s%s@%s:%s\007" "$ssh" "$user" "$host" "$pwd"
}
PROMPT_COMMAND=_prompt_command

# ===================================================================
# DO THE THINGS
# ===================================================================

# Performs initial setup if required
initializeHomelab

# set PATH so it includes homelab scripts
if [[ -d "$HOME/scripts" ]] ; then
        PATH="$HOME/scripts:$PATH"
fi

# Installs required applications
installApps

# Show system info (logo-less; -n for screenfetch, --logo none for fastfetch)
printf '\n\e[1mSystem\e[0m\n'
if command -v fastfetch >/dev/null 2>&1; then
        fastfetch --logo none
elif command -v screenfetch >/dev/null 2>&1; then
        screenfetch -n
fi
echo

# Make sure our PATH is good for all the things
if [[ -d "$HOME/.local/bin" ]] ; then
        PATH="$HOME/.local/bin:$PATH"
fi

# Check filesystem usage
if [[ -f "$HOME/scripts/check-freespace.sh" ]]; then
        diskThreshold=$(jq -r '.diskThreshold // 75' "$CONFIG_FILE")
        $HOME/scripts/check-freespace.sh "$diskThreshold"
fi

# ===================================================================
# REPOSITORY CHECKS: Report results
# ===================================================================

printf '\n\e[1mRepositories\e[0m\n'
for _i in "${!_fetch_pids[@]}"; do
        wait "${_fetch_pids[$_i]}" 2>/dev/null
        checkRepo --skip-fetch "${_fetch_repos[$_i]}"
done
unset _fetch_pids _fetch_repos _i

# ===================================================================
# DO EXTRA THINGS
# ===================================================================

# Check for bashrc.d and execute contents
if [ -d "$HOME/.bashrc.d/" ]; then
        for file in "$HOME/.bashrc.d/"*; do
        	[ -r "$file" ] && source "$file"
        done
        unset file
fi

# ===================================================================
# MAKE PROMPT FANCY
# ===================================================================
source ~/scripts/fancy-prompt.sh

# Report location
printf '\n\e[1mWelcome to \e[36m%s\e[0m!\n' "$(whereami)"
